    {
      "cell_type": "code",
      "source": [
        "# Main Execution for Incremental Pearson Correlation\n",
        "current_pearson_sums = None\n",
        "correlations_output = {}\n",
        "\n",
        "try:\n",
        "    # Check if initialization is needed (i.e., Pearson sums file doesn't exist)\n",
        "    if not os.path.exists(PEARSON_SUMS_FILE) or not os.path.exists(PRICE_HISTORY_FILE):\n",
        "        print(f\"Pearson sums file ({PEARSON_SUMS_FILE}) or price history file ({PRICE_HISTORY_FILE}) not found. Initializing...\")\n",
        "        if 'initialization_historical_df' in locals() and not initialization_historical_df.empty:\n",
        "            # Ensure the directory exists (already done in filepath cell, but good for robustness)\n",
        "            os.makedirs(os.path.dirname(PEARSON_SUMS_FILE), exist_ok=True)\n",
        "            Initialize_Pearson_Sums(initialization_historical_df, PRICE_HISTORY_FILE, PEARSON_SUMS_FILE)\n",
        "            print(\"Initialization complete. Pearson sums and price history saved.\")\n",
        "            current_pearson_sums = load_pearson_sums(PEARSON_SUMS_FILE)\n",
        "            if current_pearson_sums is None:\n",
        "                print(\"Error: Failed to load Pearson sums after initialization.\")\n",
        "        else:\n",
        "            print(\"Error: `initialization_historical_df` is not available or empty. Cannot initialize.\")\n",
        "    else:\n",
        "        print(\"Found existing Pearson sums and price history. Proceeding with update.\")\n",
        "        if 'new_daily_data_df_simulation' in locals() and not new_daily_data_df_simulation.empty:\n",
        "            current_pearson_sums = Update_Pearson_Sums(new_daily_data_df_simulation, PRICE_HISTORY_FILE, PEARSON_SUMS_FILE)\n",
        "            print(\"Update complete. Pearson sums and price history updated.\")\n",
        "            if current_pearson_sums is None:\n",
        "                 print(\"Error: Update_Pearson_Sums returned None, possibly due to an issue (e.g. files deleted, or empty data). Check logs from pearson_utils.\")\n",
        "        else:\n",
        "            print(\"No new daily data available for update or `new_daily_data_df_simulation` is empty.\")\n",
        "            current_pearson_sums = load_pearson_sums(PEARSON_SUMS_FILE) # Load existing sums\n",
        "            if current_pearson_sums is None:\n",
        "                 print(\"Error: Failed to load existing Pearson sums and no new data to process.\")\n",
        "\n",
        "    # Calculate correlations from the (potentially updated) sums\n",
        "    if current_pearson_sums is not None:\n",
        "        print(\"Calculating Pearson correlations from the latest sums...\")\n",
        "        correlations_output = Calculate_Incremental_Pearson(current_pearson_sums)\n",
        "        print(f\"Calculated {len(correlations_output)} correlations.\")\n",
        "        # Example: Print some correlations\n",
        "        count = 0\n",
        "        if correlations_output:\n",
        "            for pair, corr_value in correlations_output.items():\n",
