      "cell_type": "code",
      "source": [
        "# This cell is for preparing data for initialization vs. update.\n",
        "# For a real daily run, 'new_daily_data_df' would come from a daily data source.\n",
        "\n",
        "initialization_historical_df = pd.DataFrame() \n",
        "new_daily_data_df_simulation = pd.DataFrame() \n",
        "\n",
        "if 'stock_TimeFiltered_aggregated_close' in locals() and stock_TimeFiltered_aggregated_close is not None and not stock_TimeFiltered_aggregated_close.empty:\n",
        "    temp_df = stock_TimeFiltered_aggregated_close.reset_index()\n",
        "    # Ensure datetime conversion happens correctly\n",
        "    temp_df['date'] = pd.to_datetime(temp_df[['year', 'month', 'day']])\n",
        "    processed_stock_data = temp_df.set_index(['ticker', 'date'])[['close']].sort_index()\n",
        "    print(\"Processed stock_TimeFiltered_aggregated_close to use ('ticker', 'date') index.\")\n",
        "\n",
        "    if not processed_stock_data.empty:\n",
        "        latest_date_in_data = processed_stock_data.index.get_level_values('date').max()\n",
        "        one_year_prior_to_latest = latest_date_in_data - pd.DateOffset(years=1)\n",
        "        \n",
        "        initialization_historical_df = processed_stock_data[\n",
        "            processed_stock_data.index.get_level_values('date') > one_year_prior_to_latest\n",
        "        ].copy() # Use .copy() to avoid SettingWithCopyWarning\n",
        "        print(f\"Data for initialization spans from {initialization_historical_df.index.get_level_values('date').min()} to {initialization_historical_df.index.get_level_values('date').max()}\")\n",
        "\n",
        "        # Simulate new_daily_data as the single latest day from processed_stock_data\n",
        "        new_daily_data_df_simulation = processed_stock_data[\n",
        "            processed_stock_data.index.get_level_values('date') == latest_date_in_data\n",
        "        ].copy() # Use .copy()\n",
        "        \n",
        "        # Check if this simulated new data is essentially the last day of the init period\n",
        "        if not initialization_historical_df.empty and not new_daily_data_df_simulation.empty:\n",
        "            last_day_of_init = initialization_historical_df[initialization_historical_df.index.get_level_values('date') == latest_date_in_data]\n",
        "            if new_daily_data_df_simulation.equals(last_day_of_init):\n",
        "                 print(\"Simulation: 'New' daily data is the last day of the initialization period for this test.\")\n",
        "            else:\n",
        "                 print(f\"Simulated new daily data for date: {latest_date_in_data}\")\n",
        "        elif new_daily_data_df_simulation.empty:\n",
        "            print(\"Warning: Could not create new_daily_data_df_simulation (processed_stock_data might be empty or only have one day).\")\n",
        "    else:\n",
        "        print(\"Warning: processed_stock_data is empty. Cannot prepare initialization or simulation data.\")\n",
        "else:\n",
        "    print(\"Warning: 'stock_TimeFiltered_aggregated_close' not found, is None, or empty. Run previous cells.\")\n"
      ],
      "metadata": {
        "id": "new_data_splitting_cell",
        "collapsed": true
