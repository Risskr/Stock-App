        "                count += 1\n",
        "                if count >= 5: # Print first 5\n",
        "                    break\n",
        "        else:\n",
        "            print(\"No correlations were calculated (correlations_output is empty).\")\n",
        "    else:\n",
        "        print(\"Pearson sums are not available. Cannot calculate correlations.\")\n",
        "\n",
        "except NameError as e:\n",
        "    print(f\"A NameError occurred: {e}. This might be due to utility functions not being imported correctly or data variables not defined.\")\n",
