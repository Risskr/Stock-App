      "source": [
        "def ImportStockData():\n",
        "  # Import the stock data from My Drive\n",
        "  # Define nasdaq_stocks as the stock data\n",
        "  # Specify the full path to the file in your Google Drive\n",
        "  parquet_path = \"/content/drive/MyDrive/Colab Notebooks/usa_stocks_30m.parquet\"\n",
        "  if not os.path.exists(parquet_path):\n",
        "    print(f\"Stock data file not found at {parquet_path}. Please run DownloadStockData cell first or ensure file exists.\")\n",
        "    return None\n",
        "  nasdaq_stocks = pd.read_parquet(parquet_path)\n",
        "  return nasdaq_stocks\n"
